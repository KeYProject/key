\sorts {
  S;
}
\functions {
  S empty_set;
}
\predicates {
  isEmpty(S);
  member(S, S);
  subzet(S, S);
}


\problem {
     \forall S x1; !member(x1, empty_set)
   & \forall S x2;
       \forall S x3;
         (    subzet(x2, x3)
          <-> \forall S x4;
                (member(x4, x2) -> member(x4, x3)))
   & \forall S x5; subzet(x5, x5)
   & \forall S x6;
       (isEmpty(x6) <-> \forall S x7; !member(x7, x6))
-> \forall S x8; subzet(empty_set, x8)
}

