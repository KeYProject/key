\javaSource "./classes";

\programVariables {
  ISuper[] a;
}


\problem { 
   ((a.length = 5 & !(a=null)) & wellFormed(heap) ->
     \<{ for (int i = 0; i<a.length; i++) { a[i] = a[a.length-(i+1)]; } }\>true)
}
