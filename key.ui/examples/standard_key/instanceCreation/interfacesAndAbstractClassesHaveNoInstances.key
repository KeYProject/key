
/**
    Description: Abstract classes or interface types have no own instances.
    Provable: Yes (automatical)
*/
\javaSource "classes/";

\programVariables {
     Interface inter;
     Abstract abst;
     BC bc;
}

\problem {
    exactInstance<[Interface]>(inter) = FALSE &
  !(exactInstance<[Interface]>(inter) = TRUE) &
    exactInstance<[Abstract]>(abst) = FALSE &
  !(exactInstance<[Abstract]>(abst) = TRUE)

}
