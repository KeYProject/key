\javaSource "src/";

\programVariables {
  int a,b,c;
}

\problem {
\<{
   a=main.Outer.callM ();
   b=main.Outer.B.callM ();
   c=main.Outer.callMviaB ();
 }\> (a = 1 & b = 1 & c = 1)

}


