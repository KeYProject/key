\javaSource "src";

\rules {

 Axiom_def_modulo {
    \schemaVar \term RingBuffer r;
    \schemaVar \term Heap h;
    \schemaVar \term int x;

    \assumes (exactInstance<[RingBuffer]>(r)=TRUE ==>)
    \find(RingBuffer::modulo(h, r, x))
    \replacewith(\if(x < length(select<[int[]]>(h,r,RingBuffer::$data)))
                 \then(x)
                 \else(x-length(select<[int[]]>(h,r,RingBuffer::$data))))

    \heuristics ( simplify )
  };

}

\chooseContract
