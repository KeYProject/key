\programVariables {
   Object o1;
   Object o2;
}
\functions {
   \unique Field f;
   
   LocSet dataGroup(Heap);
   
   Heap heapAtPre;
   LocSet modAtPre;
}


\problem {
     modAtPre = dataGroup(heap)
   & heap = heapAtPre
   & subset(allFields(o1), dataGroup(heap))
-> {heap:=store(heap, o1, f, Z(3(#)))}
     \[{}\] \forall java.lang.Object o;
              \forall Field g;
                (    select<[any]>(heap, o, g)
                   = select<[any]>(heapAtPre, o, g)
                 | elementOf(o, g, modAtPre))
}

\proof {
(keyLog "0" (keyUser "boby" ) (keyVersion "1c6124905aeb4810985a67de86db42bf5ef95207"))

(autoModeTime "49")

(branch "dummy ID"
(rule "impRight" (formula "1") (newnames "heapAtPre_0,savedHeapAtPre,arg0AtPre,arg1AtPre,heapAtPre_0,savedHeapAtPre,arg0AtPre,arg1AtPre,heapAtPre_0,savedHeapAtPre,arg0AtPre,heapAtPre_0,savedHeapAtPre,vAtPre"))
(rule "andLeft" (formula "1"))
(rule "andLeft" (formula "1"))
(rule "eqSymm" (formula "4") (term "0,0,0,0,1"))
(rule "eqSymm" (formula "2"))
(rule "eqSymm" (formula "1"))
(rule "applyEq" (formula "3") (term "1") (ifseqformula "1"))
(rule "emptyModality" (formula "4") (term "1"))
 (builtin "One Step Simplification" (formula "4"))
(rule "allRight" (formula "4") (inst "sk=o_0:java.lang.Object"))
(rule "allRight" (formula "4") (inst "sk=g_0:Field"))
(rule "orRight" (formula "4"))
(rule "eqSymm" (formula "4"))
(rule "applyEq" (formula "4") (term "0,1") (ifseqformula "2"))
(rule "noElementOfSupersetImpliesNoElementOfSubset" (formula "5") (ifseqformula "3"))
 (builtin "One Step Simplification" (formula "5"))
(rule "pullOutSelect" (formula "4") (term "0") (inst "selectSK=g_0_0:any"))
(rule "simplifySelectOfStore" (formula "1"))
 (builtin "One Step Simplification" (formula "1"))
(rule "castDel" (formula "1") (term "1,0"))
(rule "eqSymm" (formula "5"))
(rule "eqSymm" (formula "1") (term "1,0,0"))
(rule "eqSymm" (formula "1") (term "0,0,0"))
(rule "replace_known_right" (formula "1") (term "0,0,0") (ifseqformula "6"))
 (builtin "One Step Simplification" (formula "1") (ifInst ""  (formula "5")))
(rule "closeFalse" (formula "1"))
)
}
