\programVariables {
   MyClass self;
}
\functions {
   Heap heapAtPre;
}

\javaSource "src";

\problem {
     !self = null
   &   select<[boolean]>(heap,
                         self,
                         java.lang.Object::#$created)
     = TRUE
   & wellFormed(heap)
   & heap = heapAtPre
   &   select<[int]>(heap, self, MyClass::#attr2)
     = Z(8(5(3(#))))
->   \[{
         self.loop1()@MyClass;
       }\]   select<[int]>(heap, self, MyClass::#attr)
           = Z(7(2(#)))
   & \forall java.lang.Object o;
       \forall Field f;
         (  o = self & f = MyClass::#attr
          |   select<[any]>(heap, o, f)
            = select<[any]>(heapAtPre, o, f))
}

