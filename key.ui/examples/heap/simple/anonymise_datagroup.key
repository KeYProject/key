\functions {
   Object o;
   \unique Field f;
   
   LocSet dataGroup(Heap);
   
   Heap heapAtPre;
   Heap anonHeap;   
   LocSet modAtPre;
}


\problem {
    //We anonymise the assignable clause "{dataGroup}", 
    //where "o2.*" is disjoint from the data group
    
    o.<created> = TRUE
    & select<[int]>(heap, o, f) = 33
    & disjoint(allFields(o), dataGroup(heap))
    & heap = heapAtPre
    & modAtPre = dataGroup(heap)
    
    ->
    
    ({heap := anon(heap, modAtPre, anonHeap)} select<[int]>(heap, o, f)) = 33
}  
