    // ============================================
    //      Complement Rules (for accessible)
    // ============================================

    \lemma
    simplifySelectOfSelfRepfpComplementAnon {
        \schemaVar \term Heap h, h2;
        \schemaVar \term Object o;
        \schemaVar \term Field f;

        \assumes(==> o = null)

        \find(select<[alpha]>(anon(h, setMinus(allLocs, repfp(o)), h2), o, f))
        \sameUpdateLevel

        \replacewith(\if(select<[boolean]>(h, o, java.lang.Object::#$created) = TRUE)
            \then(select<[alpha]>(h, o, f))
            \else(select<[alpha]>(h2, o, f)))
        \heuristics(simplify_enlarging)
    };

    \lemma
    simplifySelectOfSelfRepfpComplementAnonEQ {
        \schemaVar \term Heap h, h2, EQ;
        \schemaVar \term Object o;
        \schemaVar \term Field f;

        \assumes(anon(h, setMinus(allLocs, repfp(o)), h2) = EQ ==> o = null)
        \find(select<[alpha]>(EQ, o, f))
        \sameUpdateLevel

        \replacewith(\if(select<[boolean]>(h, o, java.lang.Object::#$created) = TRUE)
            \then(select<[alpha]>(h, o, f))
            \else(select<[alpha]>(h2, o, f)))
        \heuristics(simplify_enlarging)
    };
