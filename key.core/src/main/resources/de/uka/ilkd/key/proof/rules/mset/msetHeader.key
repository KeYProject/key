\sorts {
    \generic El;
    \generic SubEl \extends El;
    Mset<[El]>;
}

\functions {
    // Getters
    int msetMul(Mset<[El]>, El);
    int msetCard(Mset<[El]>);

    // Constructors
    Mset<[El]> msetEmpty<[El]>;
    Mset<[El]> msetSingle<[El]>(El);
    Mset<[El]> msetDiff<[El]>(Mset<[El]>, Mset<[El]>);
    Mset<[El]> msetSum<[El]>(Mset<[El]>, Mset<[El]>);
    Mset<[El]> msetRange<[El]> {false, false, true}(int, int, El);
}
