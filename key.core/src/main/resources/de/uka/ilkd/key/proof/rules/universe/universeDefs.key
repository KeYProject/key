\rules(programRules:Java) {
    // ---------------------------------------------------
    //   Introduction Rules
    // ---------------------------------------------------

    instanceCreationAssignmentRep {
        \schemaVar \modalOperator {diamond, box} #normal;
        \schemaVar \formula post;
        \schemaVar \program SimpleInstanceCreation #n, #n1;
        \schemaVar \program LocalVariable #v, #v0, #v1;
        \schemaVar \program ProgramMethod #pm;
        \schemaVar \program Type #t;

        \find(\modality{#normal}{.#pm@#t(#v).. #v0 = #n; ...}\endmodality (post))

        \sameUpdateLevel
        \varcond(\hasAnnotation(#n, universe.qual.Rep),
                 \removeAnnotation(#n1, #n, universe.qual.Rep),
                 \addAnnotation(#v1, #v0, universe.qual.Rep))

        \replacewith(\modality{#normal}{.. #v0 = #n1; #typeof(#v1) #v1 = #v0; ...}\endmodality (post))

        \heuristics(method_expand)
    };

    variableDeclarationRepAssignVariable {
        \schemaVar \modalOperator {diamond, box, diamond_transaction, box_transaction} #allmodal;
        \schemaVar \formula post;
        \schemaVar \program ProgramMethod #pm;
        \schemaVar \program Variable #v0, #v;
        \schemaVar \program Type #t, #t1;
        \schemaVar \program VariableInitializer #vi;

        \find(\modality{#allmodal}{.#pm@#t1(#v).. #t #v0 = #vi; ...}\endmodality (post))

        \sameUpdateLevel
        \varcond(\isLocalVariable(#vi), \hasAnnotation(#v0, universe.qual.Rep))

        \replacewith(\modality{#allmodal}{.. #t #v0; #v0 = #vi; ...}\endmodality (post))
        \add(#vi != null -> owner(cast<[Object]>(#vi)) = cast<[Object]>(#v) ==>)

        \heuristics(simplify_prog, simplify_prog_subset)
    };

    instanceCreationAssignmentPeer {
        \schemaVar \modalOperator {diamond, box} #normal;
        \schemaVar \formula post;
        \schemaVar \program SimpleInstanceCreation #n, #n1;
        \schemaVar \program LocalVariable #v, #v0, #v1;
        \schemaVar \program ProgramMethod #pm;
        \schemaVar \program Type #t;

        \find(\modality{#normal}{.#pm@#t(#v).. #v0 = #n; ...}\endmodality (post))

        \sameUpdateLevel
        \varcond(\hasAnnotation(#n, universe.qual.Peer),
                 \removeAnnotation(#n1, #n, universe.qual.Peer),
                 \addAnnotation(#v1, #v0, universe.qual.Peer))

        \replacewith(\modality{#normal}{.. #v0 = #n1; #typeof(#v1) #v1 = #v0; ...}\endmodality (post))

        \heuristics(method_expand)
    };

    variableDeclarationPeerAssignVariable {
        \schemaVar \modalOperator {diamond, box, diamond_transaction, box_transaction} #allmodal;
        \schemaVar \formula post;
        \schemaVar \program ProgramMethod #pm;
        \schemaVar \program Variable #v0, #v;
        \schemaVar \program Type #t, #t1;
        \schemaVar \program VariableInitializer #vi;

        \find(\modality{#allmodal}{.#pm@#t1(#v).. #t #v0 = #vi; ...}\endmodality (post))

        \sameUpdateLevel
        \varcond(\isLocalVariable(#vi), \hasAnnotation(#v0, universe.qual.Peer))

        \replacewith(\modality{#allmodal}{.. #t #v0; #v0 = #vi; ...}\endmodality (post))
        \add(#vi != null -> owner(cast<[Object]>(#vi)) = owner(cast<[Object]>(#v)) ==>)

        \heuristics(simplify_prog, simplify_prog_subset)
    };


    instanceCreationAssignmentDom {
        \schemaVar \modalOperator {diamond, box} #normal;
        \schemaVar \formula post;
        \schemaVar \program SimpleInstanceCreation #n, #n1;
        \schemaVar \program LocalVariable #v, #v0, #v1;
        \schemaVar \program ProgramMethod #pm;
        \schemaVar \program Type #t;

        \find(\modality{#normal}{.#pm@#t(#v).. #v0 = #n; ...}\endmodality (post))

        \sameUpdateLevel
        \varcond(\hasAnnotation(#n, universe.qual.Dom),
                 \removeAnnotation(#n1, #n, universe.qual.Dom),
                 \addAnnotation(#v1, #v0, universe.qual.Dom))

        \replacewith(\modality{#normal}{.. #v0 = #n1; #typeof(#v1) #v1 = #v0; ...}\endmodality (post))

        \heuristics(method_expand)
    };

    variableDeclarationDomAssignVariable {
        \schemaVar \modalOperator {diamond, box, diamond_transaction, box_transaction} #allmodal;
        \schemaVar \formula post;
        \schemaVar \program ProgramMethod #pm;
        \schemaVar \program Variable #v0, #v;
        \schemaVar \program Type #t, #t1;
        \schemaVar \program VariableInitializer #vi;

        \find(\modality{#allmodal}{.#pm@#t1(#v).. #t #v0 = #vi; ...}\endmodality (post))

        \sameUpdateLevel
        \varcond(\isLocalVariable(#vi), \hasAnnotation(#v0, universe.qual.Dom))

        \replacewith(\modality{#allmodal}{.. #t #v0; #v0 = #vi; ...}\endmodality (post))
        \add(#vi != null -> dominates(cast<[Object]>(#v), cast<[Object]>(#vi)) ==>)

        \heuristics(simplify_prog, simplify_prog_subset)
    };

    peerField {
        \schemaVar \term Object o;
        \schemaVar \term Field f;
        \schemaVar \term Heap h;

        \find(select<[alpha]>(h, o, f))
        \varcond(\hasAnnotation(f, universe.qual.Peer))
        \add(select<[alpha]>(h, o, f) != null -> owner(cast<[Object]>(o)) = owner(cast<[Object]>(select<[alpha]>(h, o, f))) ==>)
        \heuristics(type_hierarchy_def)
    };

    ownsField {
        \schemaVar \term Object o;
        \schemaVar \term Field f;
        \schemaVar \term Heap h;

        \find(select<[alpha]>(h, o, f))
        \varcond(\hasAnnotation(f, universe.qual.Rep))
        \add(select<[alpha]>(h, o, f) != null -> owner(cast<[Object]>(select<[alpha]>(h, o, f))) = o ==>)
        \heuristics(type_hierarchy_def)
    };

    dominatesField {
        \schemaVar \term Object o;
        \schemaVar \term Field f;
        \schemaVar \term Heap h;

        \find(select<[alpha]>(h, o, f))
        \varcond(\hasAnnotation(f, universe.qual.Dom))
        \add(select<[alpha]>(h, o, f) != null -> dominates(o, cast<[Object]>(select<[alpha]>(h, o, f))) ==>)
        \heuristics(type_hierarchy_def)
    };


    // ---------------------------------------------------
    //    Predicate and Function definitions
    // ---------------------------------------------------

    dominatesDepthDef {
        \schemaVar \term Object x, y;
        \schemaVar \variables Object ov;
        \schemaVar \term int n;

        \find(dominatesDepth(x, y, n))
        \varcond(\notFreeIn(ov, x, y, n))
        \replacewith(\if (n <= 0)
            \then(false)
            \else(\if (n = 1) \then(x = owner(y)) \else(\exists ov; (x = owner(ov) & dominatesDepth(ov, y, n - 1)))))
    };

    dominatesDef {
        \schemaVar \term Object x, y;
        \schemaVar \variables int n;

        \find(dominates(x, y))

        \varcond(\notFreeIn(n, x, y))
        \replacewith(\exists n; (dominatesDepth(x, y, n)))
    };

    // would make sense to be used by the automatics, but is somewhat misused and therefore not accessible by automatics
    undomDef {
        \schemaVar \term Object x, y;

        \find(undom(x, y))

        \replacewith(!dominates(x, y) & !dominates(y, x) & !(x = y))
    };

    // would make sense to be used by the automatics, but is somewhat misused and therefore not accessible by automatics
    createdRepfpDef {
        \schemaVar \term Object x;
        \schemaVar \term Heap h;
        \schemaVar \variables Object y;

        \find(createdRepfp(h, x))

        \varcond(\notFreeIn(y, x, h))

        \replacewith(intersect(infiniteUnion{y;}(\if(select<[boolean]>(h, y, java.lang.Object::#$created) = TRUE) \then(y.*) \else(empty)), repfp(x)))
    };

    repfpDef {
        \schemaVar \term Object x;
        \schemaVar \variables Object y;

        \find(repfp(x))
        \varcond(\notFreeIn(y, x))
        \replacewith(union(x.*, infiniteUnion{y;}(\if(dominates(x, y)) \then(y.*) \else(empty))))
    };


    // ---------------------------------------------------
    //    axioms for ownership
    // ---------------------------------------------------

    dominatesSelf {
        \schemaVar \term Object o;

        \find(dominates(o, o))

        \replacewith(false)

        \heuristics(concrete)
    };

    dominatesMaxDepth {
        \schemaVar \term Object x;
        \schemaVar \variables Object y;
        \schemaVar \variables int m, n;

        \find(x)

        \varcond(\notFreeIn(y, x), \notFreeIn(m, x), \notFreeIn(n, x))

        \add(\exists n; (n >= 0 & (\forall y; (dominates(x, y) ->
              (\exists m; (dominatesDepth(x, y, m) & m < n))))) ==>)
    };
}
