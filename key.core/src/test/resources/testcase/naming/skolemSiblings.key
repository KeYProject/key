// Naming harness (#3851): two sibling branches skolemize a quantifier whose bound
// variable has the same base name. Branch-local naming must give BOTH branches the
// same skolem name (names do not leak across branches), and pruning must reset them.
\predicates {
  p(int);
  q(int);
}

\problem { (\forall int idx; p(idx)) & (\forall int idx; q(idx)) }
