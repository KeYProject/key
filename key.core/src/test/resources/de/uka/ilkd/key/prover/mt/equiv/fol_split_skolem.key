// A first-order tautology that BOTH splits into independent branches (the conjunction in the
// succedent) AND forces skolemization in each branch (the universal quantifiers). This is the
// case the parallel name allocator exists for: concurrent workers minting fresh skolem names in
// sibling branches.
\sorts {
    s;
}

\predicates {
    P(s);
    Q(s);
    R(s);
}

\problem {
       ((\forall s x; P(x)) & (\forall s x; Q(x)) & (\forall s x; R(x)))
    -> ((\forall s x; P(x)) & (\forall s x; Q(x)) & (\forall s x; R(x)))
}
